modules = ["php-8.2", "bash", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_NAME = "Workflow Automation Engine"
APP_ENV = "local"
APP_DEBUG = "true"
APP_URL = "http://localhost:5000"
APP_LOCALE = "en"
APP_FALLBACK_LOCALE = "en"
APP_FAKER_LOCALE = "en_US"
APP_MAINTENANCE_DRIVER = "file"
BCRYPT_ROUNDS = "12"
LOG_CHANNEL = "stack"
LOG_STACK = "single"
LOG_DEPRECATIONS_CHANNEL = "null"
LOG_LEVEL = "debug"
DB_CONNECTION = "pgsql"
DB_HOST = "helium"
DB_PORT = "5432"
DB_DATABASE = "heliumdb"
DB_USERNAME = "postgres"
SESSION_LIFETIME = "120"
SESSION_ENCRYPT = "false"
SESSION_PATH = "/"
SESSION_DOMAIN = "null"
BROADCAST_CONNECTION = "log"
FILESYSTEM_DISK = "local"
MAIL_MAILER = "log"
MAIL_HOST = "127.0.0.1"
MAIL_PORT = "2525"
MAIL_FROM_ADDRESS = "hello@example.com"
VITE_APP_NAME = "Workflow Automation Engine"
APP_KEY = "base64:FttXaEuaddSg66zzoiqF5U/pUMlMQpxuSv/r6OrnNAc="
DB_PASSWORD = "password"

[userenv.development]
QUEUE_CONNECTION = "database"
CACHE_STORE = "database"
SESSION_DRIVER = "database"

[userenv.production]
QUEUE_CONNECTION = "redis"
CACHE_STORE = "redis"
SESSION_DRIVER = "redis"
REDIS_CLIENT = "phpredis"
HORIZON_NAME = "Workflow Engine"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php artisan config:clear 2>/dev/null; php artisan storage:link 2>/dev/null; php artisan serve --host=0.0.0.0 --port=5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "composer install --no-interaction --ignore-platform-reqs && php artisan config:clear && php artisan storage:link && php artisan migrate --force && php artisan serve --host=0.0.0.0 --port=5000"]
build = ["bash", "-c", "npm install && npm run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
