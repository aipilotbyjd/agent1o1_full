APP_NAME="Agent1o1"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://agent1o1.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
# For Neon database, use DATABASE_URL instead of individual vars
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require&channel_binding=require
# OR use individual vars (Render will convert):
# DB_HOST=ep-xxx.c-2.ap-southeast-1.aws.neon.tech
# DB_PORT=5432
# DB_DATABASE=neondb
# DB_USERNAME=neondb_owner
# DB_PASSWORD=your_secure_password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Passport OAuth
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
PASSPORT_PASSWORD_CLIENT_ID=
PASSPORT_PASSWORD_CLIENT_SECRET=
PASSPORT_CONNECTION=
